{
  "name": "leny-lima",
  "version": "1.0.0",
  "scripts": {
    "preinstall": "npm audit --audit-level=high",
    "prebuild": "node generate-sitemap.mjs && npm audit --audit-level=high",
    "ng": "node -r dotenv/config ./node_modules/@angular/cli/bin/ng.js",
    "start": "node -r dotenv/config ./node_modules/@angular/cli/bin/ng.js serve",
    "build": "node -r dotenv/config ./node_modules/@angular/cli/bin/ng.js build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr": "node dist/leny-lima/server/server.mjs",
    "images:webp": "node convert-images.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.19",
    "@angular/compiler": "^20.3.19",
    "@angular/core": "^20.3.19",
    "@angular/forms": "^20.3.19",
    "@angular/platform-browser": "^20.3.19",
    "@angular/platform-server": "^20.3.19",
    "@angular/router": "^20.3.19",
    "@angular/ssr": "^20.3.24",
    "@tailwindcss/postcss": "^4.1.18",
    "daisyui": "^5.5.14",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.24",
    "@angular/cli": "^20.3.24",
    "@angular/compiler-cli": "^20.3.19",
    "@ngx-env/builder": "^20.1.1",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}